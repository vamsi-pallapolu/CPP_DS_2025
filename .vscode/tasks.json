{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: clang++ build active file",
            "command": "/bin/bash",
            "args": [
                "-c",
                "mkdir -p '${workspaceFolder}/derived/${relativeFileDirname}' && /usr/bin/clang++ -fcolor-diagnostics -fansi-escape-codes -std=gnu++17 -g '${file}' -o '${workspaceFolder}/derived/${relativeFileDirname}/${fileBasenameNoExtension}'"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "focus": true
            },
            "detail": "Compile with clang++ into derived/ (used by the Run C/C++ File button)."
        },
    ]
}
