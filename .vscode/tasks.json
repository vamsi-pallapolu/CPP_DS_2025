{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: cl.exe build active file",
      "command": "cl.exe",
      "args": [
        "/Zi",
        "/EHsc",
        "/nologo",
        "/Fo${workspaceFolder}\\bin\\",
        "/Fd${workspaceFolder}\\bin\\",
        "/Fe${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe",
        "${file}",
        "/std:c++20",
        "/FS"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$msCompile"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    }
  ],
  "version": "2.0.0"
}
